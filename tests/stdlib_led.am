// Test the Led driver against a fake DigitalOut (no hardware).

namespace Tests

import Amalgame.Hal
import Amalgame.Hardware.Led

public class FakeOut implements DigitalOut {
    private state: int
    public FakeOut() { this.state = 0 }
    public void Write(level: int) { this.state = level }
    public void High() { this.state = 1 }
    public void Low()  { this.state = 0 }
    public void Toggle() { if (this.state == 1) { this.state = 0 } else { this.state = 1 } }
    public int StateOf() { return this.state }
}

public class FakeSpi implements SpiBus {
    private lastLen: int
    public FakeSpi() { this.lastLen = 0 }
    public List<int> Transfer(tx: List<int>) { this.lastLen = tx.Count(); return tx }
    public int LastLen() { return this.lastLen }
}

public class Program {
    public static void Main(string[] args) {
        var fail: int = 0
        let f: FakeOut = new FakeOut()
        let led: Led = new Led(f)

        led.On()
        if (f.StateOf() == 1) { Console.WriteLine("[PASS] led on") } else { Console.WriteLine("[FAIL] led on"); fail = fail + 1 }
        led.Off()
        if (f.StateOf() == 0) { Console.WriteLine("[PASS] led off") } else { Console.WriteLine("[FAIL] led off"); fail = fail + 1 }
        led.Toggle()
        if (f.StateOf() == 1) { Console.WriteLine("[PASS] led toggle") } else { Console.WriteLine("[FAIL] led toggle"); fail = fail + 1 }
        led.Set(false)
        if (f.StateOf() == 0) { Console.WriteLine("[PASS] led set(false)") } else { Console.WriteLine("[FAIL] led set(false)"); fail = fail + 1 }

        // APA102 strip: 3 LEDs → frame = 4 start + 3*4 + 1 end = 17 bytes.
        let sp: FakeSpi = new FakeSpi()
        let strip: Apa102 = new Apa102(sp, 3)
        strip.Fill(10, 20, 30)
        strip.Set(0, 255, 0, 0)
        strip.Show()
        if (sp.LastLen() == 17) { Console.WriteLine("[PASS] apa102 frame 17B") } else { Console.WriteLine("[FAIL] apa102 frame " + String_FromInt(sp.LastLen())); fail = fail + 1 }

        // WS2812: 2 px → 9 bytes/px (24 bits × 3) + 40 reset = 58 bytes.
        let sp2: FakeSpi = new FakeSpi()
        let px: Ws2812 = new Ws2812(sp2, 2)
        px.Fill(255, 0, 0)
        px.Set(1, 0, 8, 0)
        px.Show()
        if (sp2.LastLen() == 58) { Console.WriteLine("[PASS] ws2812 frame 58B") } else { Console.WriteLine("[FAIL] ws2812 frame " + String_FromInt(sp2.LastLen())); fail = fail + 1 }

        if (fail == 0) { Console.WriteLine("led: all good") }
    }
}
